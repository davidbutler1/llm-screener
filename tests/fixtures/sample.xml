      <titles>
        <title><style face="normal" font="default" size="100%">Fibrinogen levels as a predictor of outcome in isolated traumatic brain injury</style></title>
        <secondary-title><style face="normal" font="default" size="100%">Brain Injury</style></secondary-title>
